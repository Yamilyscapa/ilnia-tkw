# Per-environment API config. Do not edit by hand, generate with:
# scripts/sync-env.sh
# which reads the live keys from each running Supabase stack.
# Produces apps/api/.env.staging and apps/api/.env.production, e.g.:
APP_ENV=staging
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=