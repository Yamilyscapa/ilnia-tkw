# Production stack inputs (consumed by config.toml via env()).
# Ports offset by +1000 so both stacks run side by side. Loaded by scripts/sb.sh.
SUPABASE_PROJECT_ID=ilnia-prod
SUPABASE_API_PORT=55321
SUPABASE_DB_PORT=55322
SUPABASE_DB_SHADOW_PORT=55320
SUPABASE_STUDIO_PORT=55323
SUPABASE_INBUCKET_PORT=55324
SUPABASE_SEED_PATH=./seeds/production.sql
SUPABASE_SIGNING_KEYS_PATH=./keys/production.signing_keys.json
